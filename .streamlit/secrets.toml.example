# 复制此文件为 secrets.toml 并填入你的真实 TOKEN
# Streamlit Cloud: 在 Dashboard → Settings → Secrets 里配置
# 注意：secrets.toml 不要提交到 git！

# ── Hugging Face ──
HF_TOKEN = "hf_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── LLM API ──
LLM_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
LLM_BASE_URL = "https://api.openai.com/v1"
LLM_MODEL = "gpt-4o"
